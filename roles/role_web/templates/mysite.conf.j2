server {
    listen {{ nginx_port | default(80) }};
    server_name {% for name in nginx_server_names %}{{ name | lower }}{% if not loop.last %} {% endif %}{% endfor %};

    access_log /var/log/nginx/access_{{ nginx_root | replace('/', '_') }}.log;
    error_log /var/log/nginx/error_{{ nginx_root | replace('/', '_') }}.log;

    root {{ nginx_root }};
    index index.html index.htm;

    {% if nginx_extra_logging | default(false) %}
    log_format detailed '$remote_addr - $remote_user [$time_local] '
                        '"$request" $status $body_bytes_sent '
                        '"$http_referer" "$http_user_agent" '
                        'request_time=$request_time';
    access_log /var/log/nginx/access_detailed.log detailed;
    add_header X-Environment "staging";
    add_header X-Debug-Info "enabled";
    {% else %}
    access_log /var/log/nginx/access.log combined;
    add_header X-Environment "production";
    {% endif %}

    add_header X-Server-Name "{{ nginx_server_names[0] | upper }}";

    client_max_body_size {{ nginx_client_max_body | default('1M') }};

    location / {
        try_files $uri $uri/ =404;
    }

    location /api {
        proxy_pass http://127.0.0.1:{{ app_port | default(5000) }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Environment "{{ 'staging' if nginx_extra_logging else 'production' }}";
    }

    {% for path, alias in nginx_extra_locations | default({}) | dictsort %}
    location {{ path }} {
        alias {{ alias }};
    }
    {% endfor %}
}
